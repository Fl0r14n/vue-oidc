{
  "name": "vue-oidc-monorepo",
  "version": "1.0.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter \"*\" dev",
    "prod": "bun --filter \"*\" prod",
    "ssr": "bun --filter \"*\" --elide-lines=0 ssr",
    "ssr:prod": "bun --filter \"*\" --elide-lines=0 ssr:prod",
    "build": "bun --filter \"*\" build",
    "test": "bun --filter \"*\" test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "publish": "bun --filter vue-oidc publish"
  },
  "dependencies": {
    "bun-plugin-vue": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "vue": "latest"
  }
}

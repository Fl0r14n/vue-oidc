{
  "name": "vue-oidc-monorepo",
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter \"*\" dev",
    "build": "bun --filter \"*\" build",
    "test": "bun --filter \"*\" test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "bun-plugin-vue": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "latest",
    "typescript": "^6",
    "vue": "^3"
  }
}

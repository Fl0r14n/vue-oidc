{
  "name": "vue-oidc-sample",
  "version": "2.0.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prod": "vite --mode production",
    "ssr:dev": "bun run index",
    "ssr:prod": "NODE_ENV=production bun run index",
    "build": "run-p type-check build:lib \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/",
    "build:lib": "cd lib && run-s build",
    "build:ssr:client": "vite build --ssrManifest --outDir dist/client",
    "build:ssr:server": "vite build --ssr src/entry-server.ts --outDir dist/server",
    "build:ssr": "run-p build:lib build:ssr:*",
    "publish": "run-s build && cd lib && bun publish"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "pinia": "^3.0.4",
    "vue": "^3.5.27",
    "vue-oidc": "file:lib",
    "vue-router": "^4.6.4",
    "vuetify": "^3.11.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@microsoft/api-extractor": "^7.55.2",
    "@types/bun": "^1.3.6",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.0.9",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/eslint-plugin": "^1.6.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/language-core": "^3.2.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint-plugin-vue": "^10.7.0",
    "globals": "^17.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.0",
    "sass-embedded": "^1.97.2",
    "serve-static": "^2.2.1",
    "typescript": "^5.9.3",
    "unplugin-dts": "^1.0.0-beta.6",
    "vite": "^8.0.0-beta.8",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.0.17",
    "vue-tsc": "^3.2.2"
  }
}
